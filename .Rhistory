hIcpBpHrRr$dbp <-
    ifelse(hIcpBpHrRr$dbp < 10 | hIcpBpHrRr$dbp > 200, NA, hIcpBpHrRr$dbp)
# denoise of hr
hIcpBpHrRr$hr <-
    ifelse(hIcpBpHrRr$hr < 10, NA, hIcpBpHrRr$hr)
# denoise of rr
hIcpBpHrRr$rr <-
    ifelse(hIcpBpHrRr$rr < 10, NA, hIcpBpHrRr$rr)
summary(hIcpBpHrRr)
source("d:\\Hai\\321-stat\\1006-stat\\1006-code\\1.3 validation.r", encoding = "UTF-8")
summary(hIcpBpHrRr)
# merge
hBpHr <- merge(hbp, hhr, by = c("icuid", "interval"), all = FALSE)
hBpHrRr <- merge(hBpHr, hrr, by = c("icuid", "interval"), all = FALSE)
hIcpBpHrRr <- merge(hicp, hBpHr, by = c("icuid", "interval"), all = FALSE)
summary(hIcpBpHrRr)
head(hrr)
source("d:\\Hai\\321-stat\\1006-stat\\1006-code\\1.3 validation.r", encoding = "UTF-8")
